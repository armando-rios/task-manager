---
export const prerender = true;

import BaseLayout from "@shared/components/layouts/BaseLayout.astro";
import InteractiveFrame from "@features/landing/components/InteractiveFrame.astro";
---

<BaseLayout title="Mocha | Terminal Task Manager for Developers">
  <meta
    name="description"
    content="A high-performance task manager designed for developers. Fast, secure, and terminal-inspired."
  />
  <meta
    name="keywords"
    content="task manager, developer tools, project management, developer, coding, productivity"
  />
  <meta
    property="og:title"
    content="Mocha | Terminal Task Manager for Developers"
  />
  <meta
    property="og:description"
    content="A high-performance task manager designed for developers"
  />
  <meta property="og:type" content="website" />

  <div class="min-h-screen w-full overflow-hidden font-mono relative">
    <!-- Interactive Grid - Relativity Effect -->
    <canvas
      id="grid-canvas"
      class="absolute inset-0 pointer-events-none opacity-40"></canvas>

    <!-- Scanlines Effect -->
    <div class="absolute inset-0 scanlines pointer-events-none opacity-10">
    </div>

    <!-- Header -->
    <header
      class="relative z-50 h-16 border-b border-theme-surface-3/10 flex items-center justify-between px-4 md:px-8 bg-theme-surface-0/50 backdrop-blur-xl"
    >
      <!-- Logo -->
      <div class="flex items-center gap-3 group cursor-default">
        <div
          class="w-8 md:w-10 h-8 md:h-10 bg-theme-primary rounded-lg flex items-center justify-center font-black text-theme-surface-0 text-sm md:text-xl shadow-[0_0_20px_rgba(var(--color-theme-primary),0.4)] transition-all duration-300 group-hover:rotate-12 group-hover:scale-110"
        >
          TM
        </div>
        <div class="hidden sm:block">
          <span
            class="text-sm font-black uppercase tracking-wider text-theme-text-0"
            >Task Manager</span
          >
          <span
            class="block text-[8px] text-theme-primary font-bold opacity-60 uppercase tracking-widest italic"
            >By Armando Rios</span
          >
        </div>
      </div>

      <!-- Navigation -->
      <nav class="flex items-center gap-3 md:gap-4">
        <!-- Authenticated state (hidden by default, shown via JS) -->
        <a
          id="nav-authenticated"
          href="/dashboard"
          class="hidden group flex items-center gap-2 md:gap-3 px-4 md:px-6 py-2 bg-theme-primary/10 border border-theme-primary/30 rounded-xl text-theme-primary transition-all hover:bg-theme-primary hover:text-theme-surface-0 text-xs md:text-[10px] font-black uppercase tracking-[0.2em]"
        >
          open_dashboard
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3 md:w-4 h-3 md:h-4 group-hover:translate-x-1 transition-transform"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="3"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13 7l5 5m0 0l-5 5m5-5H6"
            />
          </svg>
        </a>

        <!-- Guest state (shown by default, hidden via JS if authenticated) -->
        <div id="nav-guest" class="flex items-center gap-3 md:gap-6">
          <a
            href="/auth/login"
            class="text-[10px] md:text-xs font-black text-theme-text-1 hover:text-theme-text-0 uppercase tracking-[0.3em] transition-colors border-b border-transparent hover:border-theme-text-0 pb-1"
          >
            login
          </a>
          <a
            href="/auth/register"
            class="px-4 md:px-6 py-2 bg-theme-surface-1 border border-theme-surface-3/50 rounded-xl text-[10px] md:text-xs font-black text-theme-text-0 uppercase tracking-[0.3em] hover:border-theme-primary/40 transition-all shadow-xl hover:scale-105"
          >
            get_started
          </a>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main
      class="relative z-10 py-8 md:py-12 lg:py-0 flex items-center justify-center min-h-[calc(100%-8rem)] px-4 md:px-8 lg:px-20"
    >
      <div
        class="max-w-6xl w-full grid lg:grid-cols-2 gap-8 lg:gap-12 items-center"
      >
        <!-- Left: Content -->
        <div
          class="space-y-6 md:space-y-8 text-center lg:text-left order-2 lg:order-1"
        >
          <div class="space-y-4">
            <!-- Badge -->
            <div
              class="inline-flex items-center gap-3 px-3 py-1 bg-theme-primary/5 border border-theme-primary/20 rounded-full"
            >
              <span class="w-2 h-2 bg-theme-primary rounded-full animate-pulse"
              ></span>
              <span
                class="text-[9px] font-black uppercase tracking-[0.4em] text-theme-primary"
                >V1.0 Stable Release</span
              >
            </div>

            <!-- Title -->
            <h1
              class="text-3xl md:text-5xl lg:text-7xl font-black tracking-tight text-theme-text-0 leading-[0.9] uppercase"
            >
              Modern Task <br />
              <span
                class="text-theme-primary drop-shadow-[0_0_30px_rgba(var(--color-theme-primary),0.3)] italic"
                >Management_</span
              >
            </h1>

            <!-- Description -->
            <p
              class="text-sm md:text-lg text-theme-text-1 font-bold leading-relaxed max-w-lg mx-auto lg:mx-0 opacity-60 italic"
            >
              A task management application to organize projects, track tasks,
              and monitor progress. Features include project creation, task
              pipelines, and productivity statistics
            </p>
          </div>

          <!-- Tech Stack -->
          <div
            class="flex flex-wrap justify-center lg:justify-start gap-3 md:gap-4 text-[10px] md:text-xs font-black uppercase tracking-[0.3em] text-theme-text-1"
          >
            <span class="opacity-40">Tech_Stack:</span>
            <span
              class="text-theme-text-0 italic border-b border-theme-primary/20"
              >ASTRO_SSR</span
            >
            <span
              class="text-theme-text-0 italic border-b border-theme-primary/20"
              >SUPABASE</span
            >
            <span
              class="text-theme-text-0 italic border-b border-theme-primary/20"
              >REACT</span
            >
          </div>
        </div>

        <!-- Right: Interactive System Frame -->
        <div
          class="order-1 lg:order-2 flex justify-center lg:justify-end"
          id="frame-container"
        >
          <InteractiveFrame />
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer
      class="absolute bottom-0 left-0 right-0 h-12 md:h-16 border-t border-theme-surface-3/10 flex items-center justify-between px-4 md:px-12 bg-theme-surface-0/30 z-50"
    >
      <div
        class="flex items-center gap-4 md:gap-8 text-[9px] md:text-xs font-black text-theme-text-1 uppercase tracking-[0.4em] italic"
      >
        <a
          href="https://armandorios.dev"
          target="_blank"
          class="hover:text-theme-primary transition-colors">armandorios.dev</a
        >
        <a
          href="https://arxdn.com"
          target="_blank"
          class="hidden md:block hover:text-theme-primary transition-colors"
          >arxdn.com</a
        >
      </div>
      <div class="flex items-center gap-2 md:gap-4">
        <span
          class="text-[9px] md:text-xs font-black uppercase tracking-[0.2em] text-theme-text-1 opacity-40 italic"
          >Open Source Project</span
        >
        <div class="flex gap-1 opacity-20">
          <div class="w-1 h-3 bg-theme-surface-3 rounded-full"></div>
          <div class="w-1 h-3 bg-theme-primary rounded-full"></div>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Grid Relativity Effect
    const canvas = document.getElementById("grid-canvas") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d");

    let mouseX = 0;
    let mouseY = 0;
    let points: {
      x: number;
      y: number;
      originalX: number;
      originalY: number;
      vx: number;
      vy: number;
    }[] = [];
    const spacing = 30;
    let cols = 0;
    let rows = 0;

    const resize = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;

      cols = Math.ceil(canvas.width / spacing) + 1;
      rows = Math.ceil(canvas.height / spacing) + 1;

      points = [];
      for (let i = 0; i < cols; i++) {
        for (let j = 0; j < rows; j++) {
          points.push({
            x: i * spacing,
            y: j * spacing,
            originalX: i * spacing,
            originalY: j * spacing,
            vx: 0,
            vy: 0,
          });
        }
      }
    };

    resize();
    window.addEventListener("resize", resize);

    const container = document.querySelector(".min-h-screen");
    container?.addEventListener("mousemove", (e) => {
      const rect = container.getBoundingClientRect();
      mouseX = (e as MouseEvent).clientX - rect.left;
      mouseY = (e as MouseEvent).clientY - rect.top;
    });

    const animate = () => {
      if (!ctx) return;

      ctx.clearRect(0, 0, canvas.width, canvas.height);

      const forceRadius = 150;
      const forceStrength = 0.8;
      const returnStrength = 0.05;
      const friction = 0.92;

      points.forEach((p) => {
        const dx = p.x - mouseX;
        const dy = p.y - mouseY;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < forceRadius) {
          const force = (1 - dist / forceRadius) * forceStrength;
          const angle = Math.atan2(dy, dx);
          p.vx += Math.cos(angle) * force;
          p.vy += Math.sin(angle) * force;
        }

        p.vx += (p.originalX - p.x) * returnStrength;
        p.vy += (p.originalY - p.y) * returnStrength;
        p.vx *= friction;
        p.vy *= friction;

        p.x += p.vx;
        p.y += p.vy;
      });

      ctx.strokeStyle = "rgba(205, 214, 244, 0.15)";
      ctx.lineWidth = 1;

      // Horizontal lines
      for (let j = 0; j < rows; j++) {
        ctx.beginPath();
        for (let i = 0; i < cols; i++) {
          const p = points[i * rows + j];
          if (i === 0) {
            ctx.moveTo(p.x, p.y);
          } else {
            ctx.lineTo(p.x, p.y);
          }
        }
        ctx.stroke();
      }

      // Vertical lines
      for (let i = 0; i < cols; i++) {
        ctx.beginPath();
        for (let j = 0; j < rows; j++) {
          const p = points[i * rows + j];
          if (j === 0) {
            ctx.moveTo(p.x, p.y);
          } else {
            ctx.lineTo(p.x, p.y);
          }
        }
        ctx.stroke();
      }

      // Highlight points near mouse
      points.forEach((p) => {
        const dx = p.x - mouseX;
        const dy = p.y - mouseY;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < forceRadius) {
          const alpha = (1 - dist / forceRadius) * 0.3;
          ctx.fillStyle = `rgba(245, 194, 231, ${alpha})`;
          ctx.beginPath();
          ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
          ctx.fill();
        }
      });

      requestAnimationFrame(animate);
    };

    animate();

    // Frame smooth 3D tilt
    const frameContainer = document.getElementById("frame-container");
    const frame = frameContainer?.querySelector("[data-frame]") as HTMLElement;

    if (frameContainer && frame) {
      let targetRotateX = 0;
      let targetRotateY = 0;
      let currentRotateX = 0;
      let currentRotateY = 0;

      const lerp = (start: number, end: number, factor: number) =>
        start + (end - start) * factor;

      frameContainer.addEventListener("mousemove", (e) => {
        const rect = frameContainer.getBoundingClientRect();
        const x = ((e as MouseEvent).clientX - rect.left) / rect.width - 0.5;
        const y = ((e as MouseEvent).clientY - rect.top) / rect.height - 0.5;

        targetRotateX = y * -15;
        targetRotateY = x * 15;
      });

      frameContainer.addEventListener("mouseleave", () => {
        targetRotateX = 0;
        targetRotateY = 0;
      });

      const animateFrame = () => {
        currentRotateX = lerp(currentRotateX, targetRotateX, 0.06);
        currentRotateY = lerp(currentRotateY, targetRotateY, 0.06);

        frame.style.transform = `perspective(1200px) rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg)`;

        requestAnimationFrame(animateFrame);
      };

      animateFrame();
    }
  });
</script>

<script>
  import { getSupabaseBrowserClient } from "@shared/lib/supabase";

  const supabase = getSupabaseBrowserClient();
  supabase.auth.getSession().then(({ data: { session } }) => {
    if (session) {
      document.getElementById("nav-authenticated")?.classList.remove("hidden");
      document.getElementById("nav-guest")?.classList.add("hidden");
    }
  });
</script>

<style>
  @keyframes scan {
    0% {
      top: 0%;
    }
    100% {
      top: 100%;
    }
  }
  .animate-scan {
    animation: scan 10s linear infinite;
  }

  #grid-canvas {
    z-index: 0;
  }
</style>

