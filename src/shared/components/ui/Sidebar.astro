---
import UserAvatar from "./UserAvatar.astro";
const { user, currentPath } = Astro.props;
---

<div
  class="hidden lg:hidden fixed w-full h-dvh bg-theme-crust/80 backdrop-blur-sm z-30"
  id="sidebar-out"
>
</div>
<aside
  class="hidden lg:static lg:flex left-0 top-0 bottom-0 w-72 max-w-[85vw] lg:w-60 flex-col glass-panel border-r border-theme-primary/10 z-40"
  id="sidebar"
>
  <!-- Logo Section -->
  <div
    class="p-4 shrink-0 flex justify-between border-b border-theme-primary/10 mb-8"
  >
    <a href="/dashboard" class="flex items-center gap-3 group">
      <div
        class="w-8 h-8 bg-theme-primary rounded-lg flex items-center justify-center font-black text-theme-base text-xs shadow-[0_0_15px_rgba(var(--color-theme-primary),0.4)] transition-transform group-hover:rotate-12"
      >
        TM
      </div>
      <span class="text-sm font-black uppercase tracking-wider text-theme-text">
        Task Manager
      </span>
    </a>
    <button
      class="p-2 rounded-lg hover:bg-theme-surface-0 transition-colors lg:hidden"
      id="mobile-menu-close"
      aria-label="Close menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-5 h-5 text-theme-text"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 overflow-y-auto custom-scrollbar px-3 min-h-0">
    <!-- Projects Section -->
    <div class="mb-4">
      <p
        class="text-[10px] text-theme-text uppercase font-black mb-2 px-2 tracking-[0.2em] flex items-center gap-2 opacity-40"
      >
        <span class="text-theme-primary">~</span> PROJECTS
      </p>
      <div class="space-y-0.5 px-1 pb-3">
        <slot name="sidebar-projects" />
      </div>
    </div>

    <!-- Tools Section -->
    <div class="mb-4">
      <p
        class="text-[10px] text-theme-text uppercase font-black mb-2 px-2 tracking-[0.2em] flex items-center gap-2 opacity-40"
      >
        <span class="text-theme-primary">~</span> TOOLS
      </p>
      <div class="space-y-0.5 px-1">
        <a
          href="/dashboard/settings"
          class={`flex items-center gap-2 px-2 py-2 text-[10px] rounded-lg transition-all uppercase font-bold group ${
            currentPath === "~/settings.conf"
              ? "bg-theme-primary/10 text-theme-primary"
              : "text-theme-subtext hover:text-theme-text hover:bg-theme-surface-0/50"
          }`}
        >
          <span
            class={`font-black text-[10px] transition-colors ${
              currentPath === "~/settings.conf"
                ? "text-theme-primary"
                : "text-theme-primary/40 group-hover:text-theme-primary"
            }`}
          >
            ./
          </span>
          <span>settings.conf</span>
        </a>
      </div>
    </div>
  </nav>

  <!-- User Section -->
  <div class="p-3 border-t border-theme-primary/10">
    <UserAvatar
      username={user?.email?.split("@")[0] ?? "User"}
      avatarUrl={`https://api.dicebear.com/7.x/pixel-art/svg?seed=${user?.id}`}
      status="online"
    />

    <!-- Logout Button -->
    <form id="logout-form" class="mt-3">
      <button
        id="logout-btn"
        type="submit"
        class="w-full px-3 py-2 text-[10px] font-black uppercase tracking-[0.2em] text-theme-subtext hover:text-theme-primary transition-all flex items-center justify-between group rounded-lg hover:bg-theme-surface-0/50"
      >
        <span>logout</span>
        <span
          class="opacity-40 group-hover:opacity-100 group-hover:text-theme-primary transition-all italic"
          >:: exit_0</span
        >
      </button>
    </form>
  </div>
</aside>
