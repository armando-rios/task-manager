---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class={`section-header mb-4`}>
  <h2
    class="text-lg md:text-xl font-bold text-theme-text mb-1 glow-text-primary animate-on-scroll"
  >
    {title}
  </h2>
  {
    subtitle && (
      <p
        class="text-theme-subtext text-sm max-w-2xl animate-on-scroll"
        style="animation-delay: 0.1s"
      >
        {subtitle}
      </p>
    )
  }
</div>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .section-header h2,
  .section-header p {
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .section-header h2,
    .section-header p {
      opacity: 1;
      animation: none;
    }
  }
</style>
