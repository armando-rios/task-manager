<div
  class="w-full max-w-md md:max-w-xl aspect-[16/10] perspective-1200"
  data-frame
>
  <!-- Main Frame - Dashboard Style -->
  <div class="w-full h-full relative">
    <!-- Ambient Glows -->
    <div
      class="absolute -top-10 -right-10 w-40 h-40 bg-theme-primary/20 rounded-full blur-3xl pointer-events-none"
    >
    </div>
    <div
      class="absolute -bottom-10 -left-10 w-32 h-32 bg-theme-secondary/15 rounded-full blur-2xl pointer-events-none"
    >
    </div>

    <!-- Main Card - Glass Panel Dashboard Style -->
    <div
      class="absolute inset-0 rounded-2xl bg-theme-base/80 backdrop-blur-xl border border-theme-surface-2/40 shadow-2xl overflow-hidden"
    >
      <!-- Top Bar -->
      <div
        class="h-8 border-b border-theme-surface-2/30 flex items-center px-3 bg-theme-surface-0/40"
      >
        <div class="flex items-center gap-1.5">
          <div class="w-3 h-3 rounded-full bg-theme-primary/70"></div>
          <div class="w-3 h-3 rounded-full bg-theme-warning/50"></div>
          <div class="w-3 h-3 rounded-full bg-theme-success/50"></div>
        </div>
      </div>

      <!-- Content -->
      <div class="flex h-[calc(100%-2rem)]">
        <!-- Sidebar - Dashboard Style -->
        <aside
          class="w-14 border-r border-theme-surface-2/30 flex flex-col items-center py-3 bg-theme-surface-0/30"
        >
          <div
            class="w-6 h-6 bg-theme-primary/80 rounded-sm mb-2 flex items-center justify-center shadow-[0_0_10px_rgba(var(--color-theme-primary),0.3)]"
          >
            <div class="w-3 h-3 bg-theme-surface-0/80 rounded-sm"></div>
          </div>
          <div class="flex flex-col gap-2 w-full px-1.5">
            <div class="h-4 w-full rounded bg-theme-primary/40 animate-pulse">
            </div>
            <div class="h-4 w-full rounded bg-theme-surface-1/40"></div>
            <div class="h-4 w-full rounded bg-theme-surface-1/40"></div>
            <div class="h-4 w-full rounded bg-theme-surface-1/30"></div>
          </div>
          <div
            class="mt-auto w-5 h-5 rounded-full border-2 border-theme-priority-high/30 shadow-[0_0_8px_rgba(var(--color-theme-priority-high),0.2)]"
          >
          </div>
        </aside>

        <!-- Main Content - Dashboard Style -->
        <div class="flex-1 flex flex-col p-3 gap-3">
          <!-- Stats - Dashboard Cards -->
          <div class="grid grid-cols-3 gap-3">
            <div
              class="p-3 rounded-xl bg-theme-surface-0/40 border border-theme-surface-1/30 shadow-lg"
            >
              <div class="h-2 w-full rounded-full bg-theme-text-0/15 mb-2">
              </div>
              <div
                class="h-6 w-10 rounded bg-theme-primary/50 shadow-[0_0_8px_rgba(var(--color-theme-primary),0.2)]"
              >
              </div>
            </div>
            <div
              class="p-3 rounded-xl bg-theme-surface-0/40 border border-theme-surface-1/30 shadow-lg"
            >
              <div class="h-2 w-full rounded-full bg-theme-text-0/15 mb-2">
              </div>
              <div
                class="h-6 w-10 rounded bg-theme-warning/50 shadow-[0_0_8px_rgba(var(--color-theme-warning),0.2)]"
              >
              </div>
            </div>
            <div
              class="p-3 rounded-xl bg-theme-surface-0/40 border border-theme-surface-1/30 shadow-lg"
            >
              <div class="h-2 w-full rounded-full bg-theme-text-0/15 mb-2">
              </div>
              <div
                class="h-6 w-10 rounded bg-theme-success/50 shadow-[0_0_8px_rgba(var(--color-theme-success),0.2)]"
              >
              </div>
            </div>
          </div>

          <!-- Projects - Dashboard Cards -->
          <div class="flex-1 flex flex-col gap-2 min-h-0">
            <div class="flex items-center gap-2">
              <div
                class="w-2 h-2.5 bg-theme-primary/60 rounded-full animate-pulse shadow-[0_0_6px_rgba(var(--color-theme-primary),0.3)]"
              >
              </div>
              <div class="h-2.5 w-20 rounded bg-theme-text-0/15"></div>
            </div>

            <!-- Cards - Dashboard Style -->
            <div class="space-y-2">
              <div
                class="p-3 rounded-xl bg-theme-surface-0/30 border border-theme-surface-1/20 flex items-center gap-3 shadow-lg hover:border-theme-primary/20 transition-colors"
              >
                <div
                  class="w-3 h-3 rounded-full bg-theme-primary/60 animate-pulse shadow-[0_0_6px_rgba(var(--color-theme-primary),0.3)]"
                >
                </div>
                <div class="h-2 flex-1 rounded bg-theme-text-0/15"></div>
                <div class="h-3 w-12 rounded bg-theme-surface-1/30">
                  <div
                    class="h-full w-3/4 bg-gradient-to-r from-theme-primary/50 to-theme-success/50 rounded shadow-[0_0_6px_rgba(var(--color-theme-primary),0.2)]"
                  >
                  </div>
                </div>
              </div>
              <div
                class="p-3 rounded-xl bg-theme-surface-0/30 border border-theme-surface-1/20 flex items-center gap-3 shadow-lg hover:border-theme-warning/20 transition-colors"
              >
                <div
                  class="w-3 h-3 rounded-full bg-theme-warning/50 shadow-[0_0_6px_rgba(var(--color-theme-warning),0.2)]"
                >
                </div>
                <div class="h-2 flex-1 rounded bg-theme-text-0/15"></div>
                <div class="h-3 w-12 rounded bg-theme-surface-1/30">
                  <div
                    class="h-full w-1/2 bg-gradient-to-r from-theme-warning/50 to-theme-peach/50 rounded shadow-[0_0_6px_rgba(var(--color-theme-warning),0.2)]"
                  >
                  </div>
                </div>
              </div>
              <div
                class="p-3 rounded-xl bg-theme-surface-0/30 border border-theme-surface-1/20 flex items-center gap-3 shadow-lg hover:border-theme-info/20 transition-colors"
              >
                <div
                  class="w-3 h-3 rounded-full bg-theme-info/50 shadow-[0_0_6px_rgba(var(--color-theme-info),0.2)]"
                >
                </div>
                <div class="h-2 flex-1 rounded bg-theme-text-0/15"></div>
                <div class="h-3 w-12 rounded bg-theme-surface-1/30">
                  <div
                    class="h-full w-1/4 bg-gradient-to-r from-theme-info/50 to-theme-sapphire/50 rounded shadow-[0_0_6px_rgba(var(--color-theme-info),0.2)]"
                  >
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Quick Actions -->
          <div class="grid grid-cols-3 gap-3">
            <div
              class="p-2.5 rounded-xl bg-theme-primary/25 border border-theme-primary/30 flex items-center justify-center shadow-lg hover:bg-theme-primary/30 transition-colors cursor-pointer"
            >
              <div
                class="w-2.5 h-2.5 rounded bg-theme-primary/60 shadow-[0_0_6px_rgba(var(--color-theme-primary),0.3)]"
              >
              </div>
            </div>
            <div
              class="p-2.5 rounded-xl bg-theme-surface-0/40 border border-theme-surface-1/30 shadow-lg"
            >
            </div>
            <div
              class="p-2.5 rounded-xl bg-theme-surface-0/40 border border-theme-surface-1/30 shadow-lg"
            >
            </div>
          </div>
        </div>
      </div>

      <!-- Scan Line -->
      <div
        class="absolute left-0 right-0 h-px bg-gradient-to-r from-transparent via-theme-primary/20 to-transparent frame-scan"
      >
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes frame-scan {
    0% {
      top: 5%;
      opacity: 0;
    }
    20% {
      opacity: 0.25;
    }
    80% {
      opacity: 0.25;
    }
    100% {
      top: 95%;
      opacity: 0;
    }
  }

  .frame-scan {
    animation: frame-scan 5s linear infinite;
  }

  [data-frame] {
    transform-style: preserve-3d;
    transition: transform 0.2s ease-out;
  }
</style>

